# ─── Provider LLM ────────────────────────────────────────────
# Choix du cerveau de Jarvis : "anthropic" (défaut) ou "gemini"
JARVIS_PROVIDER=anthropic

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
JARVIS_ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (https://aistudio.google.com/apikey) — gratuit jusqu'à 1M tokens/jour
GEMINI_API_KEY=
JARVIS_GEMINI_MODEL=gemini-2.0-flash

# ─── Serveur ─────────────────────────────────────────────────
JARVIS_SECRET_TOKEN=change_this_secret_token_123
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# ─── Optionnel ───────────────────────────────────────────────
# Brave Search API pour de meilleurs résultats web (DuckDuckGo sinon)
BRAVE_API_KEY=
# Timeout par défaut pour les appels RPC vers les workers distants (secondes)
JARVIS_RPC_TIMEOUT=60
