# ─── Provider LLM ────────────────────────────────────────────
# Choix du cerveau d'Orion : "anthropic" | "gemini" | "ollama" (local, offline)
ORION_PROVIDER=anthropic

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ORION_ANTHROPIC_MODEL=claude-sonnet-4-6

# Google Gemini (https://aistudio.google.com/apikey) — gratuit jusqu'à 1M tokens/jour
GEMINI_API_KEY=
ORION_GEMINI_MODEL=gemini-2.0-flash

# Ollama — LLM 100% local (https://ollama.com), pas de clé API, pas d'internet
# Prérequis : `ollama serve` doit tourner ; télécharge un modèle qui supporte
# le tool calling : `ollama pull llama3.1:8b` (rapide, ~5 GB) ou
# `ollama pull qwen2.5:14b` (meilleur tool calling, ~9 GB).
# Pour le 70B Q2 : ~26 GB, lent (~1 tok/s) en CPU sans GPU.
ORION_OLLAMA_MODEL=llama3.1:8b
ORION_OLLAMA_HOST=http://localhost:11434

# Fallback automatique : si le 1er échoue (rate limit, hors quota, internet down…),
# bascule sur le suivant. Sticky : le 1er qui marche reste actif tant qu'il marche.
# Active avec : ORION_PROVIDER=fallback
ORION_FALLBACK_CHAIN=anthropic,gemini,ollama

# ─── Serveur ─────────────────────────────────────────────────
ORION_SECRET_TOKEN=change_this_secret_token_123
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# ─── Confirmation par mot de passe (actions destructives) ────
# Si défini : Orion demande ce mot de passe avant d'exécuter une action
# dangereuse (delete_file, run_shell_command, mouse_click, etc.).
# DOIT être différent du token serveur. Vide = pas de gating.
ORION_CONFIRM_PASSWORD=
ORION_CONFIRM_CACHE_SEC=0
ORION_CONFIRM_TIMEOUT_SEC=120
# ORION_CONFIRM_TOOLS=delete_file,run_shell_command,run_python_script

# ─── Audit log + notifications push ─────────────────────────
ORION_AUDIT_ENABLED=true
ORION_AUDIT_MAX_ROWS=10000
# Push mobile via ntfy.sh : crée un topic et abonne-toi via l'app ntfy mobile.
# Tu reçois un push pour chaque action sensible exécutée.
ORION_NTFY_TOPIC=
# ORION_NTFY_SERVER=https://ntfy.sh

# ─── Backups auto avant action destructive ───────────────────
ORION_BACKUP_ENABLED=true
ORION_BACKUP_DAYS=7
ORION_BACKUP_MAX_MB=100

# ─── Rate limit anti-abus ────────────────────────────────────
ORION_RATE_LIMIT_ENABLED=true
ORION_RATE_LIMIT_PER_MIN=10
ORION_RATE_LIMIT_BURST=3
ORION_RATE_LIMIT_BURST_WINDOW=5

# ─── Tokens scopés (optionnel, sinon SECRET_TOKEN sert pour tout) ─
# ORION_TOKEN_USER=
# ORION_TOKEN_WORKER=
# ORION_TOKEN_ADMIN=

# ─── Optionnel ───────────────────────────────────────────────
# Brave Search API pour de meilleurs résultats web (DuckDuckGo sinon)
BRAVE_API_KEY=
# Timeout par défaut pour les appels RPC vers les workers distants (secondes)
ORION_RPC_TIMEOUT=60

# ─── Voix locale (mode `python start.py voice`) ──────────────
# Identifiant de session WebSocket pour le service voix
# (sinon dérivé du hostname automatiquement)
# ORION_VOICE_DEVICE_ID=voice-mon-pc

# Backend STT : faster-whisper (par défaut). Voir voice/registry.py pour la liste.
ORION_VOICE_STT_BACKEND=faster-whisper
# Modèle Whisper : tiny | base | small | medium | large-v3
ORION_VOICE_STT_MODEL=small
# Device d'inférence Whisper : cpu | cuda
ORION_VOICE_STT_DEVICE=cpu
# Quantisation : int8 (CPU léger) | float16 (GPU rapide) | float32
ORION_VOICE_STT_COMPUTE=int8
# Langue parlée à Orion (fr | en | es | de | …)
ORION_VOICE_STT_LANG=fr

# Backend TTS : kokoro (par défaut). Voir voice/registry.py pour la liste.
ORION_VOICE_TTS_BACKEND=kokoro
# Voix Kokoro : ff_siwis (FR féminine), am_fenrir (EN masculine), …
# Voir https://github.com/thewh1teagle/kokoro-onnx pour la liste complète
ORION_VOICE_TTS_VOICE=ff_siwis
ORION_VOICE_TTS_SPEED=1.0
ORION_VOICE_TTS_LANG=fr-fr

# Wake words séparés par virgules. Mettre vide pour désactiver le wake word.
ORION_VOICE_WAKE_WORDS=hey orion,orion
# True = écoute toujours active (pas de wake word)
ORION_VOICE_WAKE_ENABLED=true
# Bascule en mode wake word après N secondes d'inactivité
ORION_VOICE_WAKE_TIMEOUT=120
# Fenêtre follow-up : écoute la suite sans wake word pendant N s après une réponse
# (style Alexa/Siri). 0 pour désactiver.
ORION_VOICE_FOLLOWUP_SEC=15

# Mots qui déverrouillent l'UI navigateur via la voix (court-circuite le LLM).
# Édite aussi PASSWORDS dans orion_ui.html (~ligne 1556) pour rester synchro.
ORION_VOICE_UNLOCK_WORDS=ouverture,ouvre toi,deverrouille,orion ouverture,orion ouvre

# HuggingFace token (optionnel, supprime le warning au démarrage)
# https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxx

# ─── Briefing matinal vocal automatique ──────────────────────
# Envoie chaque jour à l'heure dite un résumé vocal (météo + agenda + emails).
# Nécessite : un service voix (start.py voice) connecté au serveur, plus
# l'OAuth Google si tu veux gmail+calendar dans le briefing.
# Le device cible est auto-détecté (premier client 'voice-*' actif), ou force
# avec ORION_BRIEFING_DEVICE=voice-mon-pc.
ORION_BRIEFING_ENABLED=false
ORION_BRIEFING_TIME=08:00
ORION_BRIEFING_WEEKDAYS=mon,tue,wed,thu,fri
# ORION_BRIEFING_DEVICE=voice-astrakernel

# Capture micro (avancé)
# ORION_VOICE_VAD_LEVEL=3
# ORION_VOICE_SILENCE_SHORT_MS=520
# ORION_VOICE_SILENCE_LONG_MS=950
# ORION_VOICE_MAX_RECORD_SEC=30

# Dossier où stocker les modèles Kokoro (auto-DL au premier run, ~300 MB)
# ORION_VOICE_KOKORO_DIR=data/kokoro

# ─── Google Workspace (Gmail + Calendar) ─────────────────────
# Tools : gmail_search, gmail_read_message, calendar_list_events, calendar_create_event
#
# Setup (à faire une fois) :
#   1. https://console.cloud.google.com/apis/credentials
#   2. Créer un projet, activer "Gmail API" + "Google Calendar API"
#   3. Créer un OAuth 2.0 Client ID type "Desktop app"
#   4. Télécharger credentials.json → data/google/credentials.json
#   5. Au premier appel d'un tool Gmail/Calendar, un navigateur s'ouvre
#      pour autoriser. Le token est sauvegardé dans data/google/token.json
#      et rafraîchi automatiquement ensuite.
#
# Installer les deps : pip install -r requirements-google.txt
#
# Chemins personnalisés (optionnel) :
# ORION_GOOGLE_CREDENTIALS=data/google/credentials.json
# ORION_GOOGLE_TOKEN=data/google/token.json

# ─── Automation souris/clavier (DANGEREUX) ───────────────────
# Désactivé par défaut. Active uniquement si tu fais confiance aux tools
# mouse_*/keyboard_*. Failsafe : déplacer souris coin haut-gauche coupe.
# Installe : pip install -r requirements-extras.txt
ORION_AUTOMATION_ENABLED=false

# ─── Génération d'images (Gemini Imagen) ─────────────────────
# Utilise GEMINI_API_KEY déjà configurée.
# Modèle par défaut : imagen-3.0-fast-generate-001 (rapide, économique)
# Alternative : imagen-3.0-generate-002 (qualité photo)
# ORION_IMAGE_MODEL=imagen-3.0-fast-generate-001

# ─── Mémoire long terme vectorielle (RAG) ────────────────────
# Tools : memory_remember, memory_recall, memory_index_file, memory_index_dir, …
# Installe : pip install -r requirements-rag.txt
# 1er run télécharge ~118 MB depuis HuggingFace.
# ORION_MEMORY_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
